generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("PRISMA_DATABASE_URL")
  directUrl = env("POSTGRES_URL")
}

model User {
  id               String        @id @default(cuid())
  username         String        @unique
  avatar           String?
  wins             Int           @default(0)
  losses           Int           @default(0)
  createdAt        DateTime      @default(now())
  achievements     Achievement[]
  matches          Battle[]
  receivedRequests Friendship[]  @relation("FriendshipAddressee")
  sentRequests     Friendship[]  @relation("FriendshipRequester")
}

model Friendship {
  id          String   @id @default(cuid())
  requesterId String
  addresseeId String
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  addressee   User     @relation("FriendshipAddressee", fields: [addresseeId], references: [id])
  requester   User     @relation("FriendshipRequester", fields: [requesterId], references: [id])

  @@unique([requesterId, addresseeId])
}

model Achievement {
  id         String   @id @default(cuid())
  userId     String
  key        String
  unlockedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, key])
}

model Battle {
  id        String   @id @default(cuid())
  playerId  String
  opponent  String
  winner    String
  logs      String[]
  createdAt DateTime @default(now())
  player    User     @relation(fields: [playerId], references: [id])
}

model Room {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  host      String
  guest     String?
  status    String   @default("WAITING")
  isPrivate Boolean  @default(false)
}

model StatsCache {
  id        String   @id @default(cuid())
  username  String   @unique
  data      Json
  fetchedAt DateTime @default(now())
}
